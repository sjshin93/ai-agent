LOG_LEVEL=info

VERSION=0.1.0
AUTO_LOGOUT_SECONDS=300
OAUTH_TOKEN_URL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/google/callback
GOOGLE_SUCCESS_REDIRECT=/login?google=ok
GOOGLE_FAILURE_REDIRECT=/login?google=error
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:8080/api/auth/kakao/callback
KAKAO_SUCCESS_REDIRECT=/login?kakao=ok
KAKAO_FAILURE_REDIRECT=/login?kakao=error

SERVER_HOST=0.0.0.0
SERVER_PORT=8000

SLACK_WEBHOOK_URL=

OPENWEBUI_BASE_URL=http://192.168.3.20/api
OPENWEBUI_API_KEY=
OPENWEBUI_CHAT_PATH=/v1/chat/completions
OPENWEBUI_DEFAULT_MODEL=

HTTP_TIMEOUT=5
HTTP_RETRY=3

POSTGRES_DSN=postgresql://app:app@postgres:5432/app
REDIS_URL=redis://redis:6379/0

POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_POOL_MIN_SIZE=1
POSTGRES_POOL_MAX_SIZE=10

SESSION_CLEANUP_INTERVAL_SECONDS=60
SESSION_RETENTION_SECONDS=120

COLLECTION_FILE=./backend/collection.json
COLLECTION_PATH=/app/collection.json
